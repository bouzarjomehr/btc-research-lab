    "from pathlib import Path\n",
    "import os\n",
    "\n",
    "root = Path.cwd()\n",
    "\n",
    "while not (root / \".git\").exists():\n",
    "    root = root.parent\n",
    "\n",
    "os.chdir(root)\n",
    "\n",
    "print(\"Project root:\", root)"
   ]
